# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated list of Telegram chat IDs to receive notifications
# Use /myid command to get your chat ID
TELEGRAM_CHAT_IDS=123456789,987654321

# Optional: Restrict bot usage to specific user IDs (leave empty to allow all)
# Comma-separated list of Telegram user IDs
ALLOWED_USER_IDS=

# WG-Gesucht Search URLs
# Get these URLs from wg-gesucht.de after setting your search filters
WG_SEARCH_URL_ERLANGEN=https://www.wg-gesucht.de/wg-zimmer-in-Erlangen.70.0.1.0.html
WG_SEARCH_URL_NUERNBERG=https://www.wg-gesucht.de/wg-zimmer-in-Nuernberg.90.0.1.0.html

# Bot Settings
# How often to check for new listings (in seconds)
# Default: 180 (3 minutes)
CHECK_SECONDS=180

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
